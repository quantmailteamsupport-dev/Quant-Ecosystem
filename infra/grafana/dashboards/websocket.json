{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "targets": [
        {
          "expr": "sum(ws_active_connections)",
          "legendFormat": "Active Connections",
          "refId": "A"
        }
      ],
      "title": "Active Connections",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(ws_messages_received_total[$__rate_interval]))",
          "legendFormat": "Messages In",
          "refId": "A"
        },
        {
          "expr": "sum(rate(ws_messages_sent_total[$__rate_interval]))",
          "legendFormat": "Messages Out",
          "refId": "B"
        }
      ],
      "title": "Message Rate (In/Out)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(ws_connection_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(ws_connection_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(ws_connection_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ],
      "title": "Connection Duration Histogram",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "id": 4,
      "targets": [
        {
          "expr": "sum(rate(ws_backpressure_events_total[$__rate_interval]))",
          "legendFormat": "Backpressure Events",
          "refId": "A"
        }
      ],
      "title": "Backpressure Events",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "id": 5,
      "targets": [
        {
          "expr": "sum by (channel) (ws_subscriptions_total)",
          "legendFormat": "{{channel}}",
          "refId": "A"
        }
      ],
      "title": "Subscription Count per Channel",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "id": 6,
      "targets": [
        {
          "expr": "ws_memory_per_connection_bytes",
          "legendFormat": "Memory per Connection",
          "refId": "A"
        }
      ],
      "title": "Memory per Connection",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "id": 7,
      "targets": [
        {
          "expr": "sum(rate(ws_reconnections_total[$__rate_interval]))",
          "legendFormat": "Reconnection Rate",
          "refId": "A"
        }
      ],
      "title": "Reconnection Rate",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["quant", "websocket"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "WebSocket Gateway",
  "uid": "quant-websocket-gateway",
  "version": 1
}
