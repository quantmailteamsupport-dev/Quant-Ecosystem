{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"$service\"}[$__rate_interval]))",
          "legendFormat": "Request Rate",
          "refId": "A"
        }
      ],
      "title": "Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"$service\", status_code=~\"5..\"}[$__rate_interval]))",
          "legendFormat": "5xx Error Rate",
          "refId": "A"
        }
      ],
      "title": "Error Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"$service\"}[$__rate_interval])))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"$service\"}[$__rate_interval])))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"$service\"}[$__rate_interval])))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ],
      "title": "Latency Histogram",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "percent" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "id": 4,
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{pod=~\"$service.*\"}[$__rate_interval]) * 100",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "title": "CPU Usage",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "id": 5,
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{pod=~\"$service.*\"}",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "title": "Memory Usage",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "id": 6,
      "targets": [
        {
          "expr": "rate(nodejs_gc_duration_seconds_sum{service=\"$service\"}[$__rate_interval])",
          "legendFormat": "{{gc_type}}",
          "refId": "A"
        }
      ],
      "title": "GC Pause Duration",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "id": 7,
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_seconds{service=\"$service\"}",
          "legendFormat": "Event Loop Lag",
          "refId": "A"
        }
      ],
      "title": "Event Loop Lag",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "id": 8,
      "targets": [
        {
          "expr": "db_pool_active_connections{service=\"$service\"}",
          "legendFormat": "Active",
          "refId": "A"
        },
        {
          "expr": "db_pool_idle_connections{service=\"$service\"}",
          "legendFormat": "Idle",
          "refId": "B"
        },
        {
          "expr": "db_pool_waiting_connections{service=\"$service\"}",
          "legendFormat": "Waiting",
          "refId": "C"
        }
      ],
      "title": "Connection Pool Stats",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "id": 9,
      "targets": [
        {
          "expr": "kube_pod_container_status_restarts_total{pod=~\"$service.*\"}",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "title": "Pod Restarts",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "id": 10,
      "targets": [
        {
          "expr": "process_resident_memory_bytes{service=\"$service\"}",
          "legendFormat": "RSS",
          "refId": "A"
        },
        {
          "expr": "nodejs_heap_size_used_bytes{service=\"$service\"}",
          "legendFormat": "Heap Used",
          "refId": "B"
        }
      ],
      "title": "Process Memory Detail",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "id": 11,
      "targets": [
        {
          "expr": "nodejs_active_handles_total{service=\"$service\"}",
          "legendFormat": "Active Handles",
          "refId": "A"
        },
        {
          "expr": "nodejs_active_requests_total{service=\"$service\"}",
          "legendFormat": "Active Requests",
          "refId": "B"
        }
      ],
      "title": "Node.js Internals",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "percentunit" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "id": 12,
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"$service\", status_code=~\"5..\"}[$__rate_interval])) / sum(rate(http_requests_total{service=\"$service\"}[$__rate_interval]))",
          "legendFormat": "Error Percentage",
          "refId": "A"
        }
      ],
      "title": "Error Percentage",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["quant", "service-detail"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "identity", "value": "identity" },
        "datasource": "Prometheus",
        "definition": "label_values(http_requests_total, service)",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "service",
        "options": [
          { "selected": true, "text": "identity", "value": "identity" },
          { "selected": false, "text": "chat-api", "value": "chat-api" },
          { "selected": false, "text": "mail-api", "value": "mail-api" },
          { "selected": false, "text": "ai-api", "value": "ai-api" },
          { "selected": false, "text": "sync-api", "value": "sync-api" },
          { "selected": false, "text": "ads-api", "value": "ads-api" },
          { "selected": false, "text": "tube-api", "value": "tube-api" },
          { "selected": false, "text": "neon-api", "value": "neon-api" },
          { "selected": false, "text": "edits-api", "value": "edits-api" },
          { "selected": false, "text": "max-api", "value": "max-api" },
          { "selected": false, "text": "ws-gateway", "value": "ws-gateway" }
        ],
        "query": "label_values(http_requests_total, service)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Service Detail - $service",
  "uid": "quant-service-detail",
  "version": 1
}
