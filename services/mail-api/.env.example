# Server Configuration
PORT=3001
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info

# CORS
CORS_ORIGINS=https://quant.io

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# Authentication
JWT_SECRET=your-secure-secret-here
JWT_ISSUER=mail-api
JWT_AUDIENCE=quant-ecosystem

# Redis
REDIS_URL=redis://redis:6379

# Database
DATABASE_URL=postgresql://user:pass@host:5432/quantdb

# SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@quant.io
SMTP_PASS=your-smtp-password

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=mail-api
