# Server Configuration
PORT=3006
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info

# CORS
CORS_ORIGINS=https://quant.io

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# Authentication
JWT_SECRET=your-secure-secret-here
JWT_ISSUER=tube-api
JWT_AUDIENCE=quant-ecosystem

# Redis
REDIS_URL=redis://redis:6379

# Database
DATABASE_URL=postgresql://user:pass@host:5432/quantdb

# Object Storage
S3_BUCKET=quant-uploads
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Video Processing
VIDEO_TRANSCODE_QUEUE=quant-video-transcode
VIDEO_MAX_SIZE_MB=5120

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=tube-api
