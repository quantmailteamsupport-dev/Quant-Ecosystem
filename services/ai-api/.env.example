# Server Configuration
PORT=3020
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info

# CORS
CORS_ORIGINS=https://quant.io

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# Authentication
JWT_SECRET=your-secure-secret-here
JWT_ISSUER=ai-api
JWT_AUDIENCE=quant-ecosystem

# Redis
REDIS_URL=redis://redis:6379

# Database
DATABASE_URL=postgresql://user:pass@host:5432/quantdb

# AI Configuration
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL_DEFAULT=gpt-4
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=ai-api
